{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "MICAFP UnifiedShield VIP-ULTRA",
  "uid": "shield-vip-ultra",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1, "title": "DPI Detection Probability", "type": "gauge",
      "targets": [{"expr": "shield_dpi_detection_probability", "datasource": {"uid": "$DS_PROMETHEUS"}}],
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [
        {"color": "green", "value": 0},
        {"color": "yellow", "value": 0.3},
        {"color": "red", "value": 0.7}
      ]}}}
    },
    {
      "id": 2, "title": "Bytes Sent/Received (Total)", "type": "stat",
      "targets": [
        {"expr": "shield_bytes_sent_total", "legendFormat": "Sent"},
        {"expr": "shield_bytes_recv_total", "legendFormat": "Received"}
      ]
    },
    {
      "id": 3, "title": "Connection Latency (P99)", "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.99, shield_connection_latency_ms_bucket)", "legendFormat": "P99"}]
    },
    {
      "id": 4, "title": "Core Switches Total", "type": "stat",
      "targets": [{"expr": "shield_core_switches_total"}]
    },
    {
      "id": 5, "title": "NAIN Status", "type": "stat",
      "targets": [{"expr": "shield_nain_status", "legendFormat": "NAIN"}],
      "fieldConfig": {"defaults": {"mappings": [
        {"type": "value", "options": {"0": {"text": "Normal"}, "1": {"text": "Partial"}, "2": {"text": "Shutdown"}}}
      ]}}
    },
    {
      "id": 6, "title": "P2P Active Peers", "type": "stat",
      "targets": [{"expr": "shield_p2p_peers_active"}]
    },
    {
      "id": 7, "title": "Post-Quantum KEX Total", "type": "stat",
      "targets": [{"expr": "shield_post_quantum_kex_total"}]
    },
    {
      "id": 8, "title": "Uptime", "type": "stat",
      "targets": [{"expr": "shield_uptime_seconds"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
