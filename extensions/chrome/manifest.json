{
  "manifest_version": 3,
  "name": "UnifiedShield VPN",
  "version": "6.0.0",
  "description": "Anti-censorship VPN tunnel for Iran — WebTransport/HTTPS proxy with traffic obfuscation",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "UnifiedShield"
  },
  "permissions": [
    "proxy",
    "webRequest",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.deno.dev/*",
    "https://*.val.town/*",
    "https://*.supabase.co/*",
    "https://*.netlify.app/*",
    "https://*.arvancloud.com/*",
    "https://*.arvancdn.ir/*",
    "https://*.arvancloud.ir/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "minimum_chrome_version": "116",
  "web_accessible_resources": [
    {
      "resources": ["wasm/obfuscator.wasm"],
      "matches": ["<all_urls>"]
    }
  ]
}
