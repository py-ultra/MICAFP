# UnifiedShield iOS Podfile
# CDN: Alibaba/Tencent primary (Cloudflare BLOCKED in Iran)

source 'https://cdn.cocoapods.org/'
# Fallback: use Alibaba mirror if CocoaPods CDN is blocked
# source 'https://mirrors.aliyun.com/CocoaPods/Specs.git'

platform :ios, '15.0'
use_frameworks!

# Main app target
target 'UnifiedShield' do
  pod 'SwiftUI', '~> 5.0'
  pod 'KeychainAccess', '~> 4.2'
  pod 'SwiftyJSON', '~> 5.0'
end

# Network Extension target (for VPN functionality)
target 'UnifiedShieldPacketTunnel' do
  # Minimal dependencies for the packet tunnel
  # Rust FFI core is linked as a static library, not a CocoaPod
  pod 'SwiftyJSON', '~> 5.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['SWIFT_VERSION'] = '5.9'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
