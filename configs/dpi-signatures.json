    {
      "signature_id": "DPI-006",
      "name": "Protocol-Detect",
      "description": "Protocol detection and fingerprinting - identifies VPN/proxy protocols by traffic patterns",
      "description_fa": "شناسایی و اثرانگشت پروتکل - تشخیص پروتکل‌های VPN/proxy با الگوی ترافیک",
      "detection_method": "traffic_pattern_analysis",
      "response_pattern": "connection_throttle_or_reset",
      "timing_ms_min": 500,
      "timing_ms_max": 5000,
      "affected_isps": [
        "AS41689",
        "AS39074",
        "AS34918",
        "AS16322",
        "AS24631",
        "AS12880",
        "AS44244"
      ],
      "technical_details": {
        "trigger": "Traffic pattern matches known VPN/proxy protocol fingerprint",
        "detected_protocols": {
          "openvpn": "UDP on custom ports with TLS-like initial packet",
          "wireguard": "UDP with specific handshake_init message format",
          "shadowsocks": "Stream cipher patterns, fixed-length IV",
          "trojan": "TLS with unusual certificate patterns",
          "v2ray_vmess": "Custom protocol with UUID-based authentication",
          "ssr": "Custom auth header patterns"
        },
        "detection_technique": "ML-based traffic classification + DPI rule matching",
        "bypass_methods": [
          "traffic_obfuscation",
          "padding",
          "flow_morphing",
          "domain_fronting",
          "meek_transport",
          "packet_fragmentation"
        ]
      }
    },
    {
      "signature_id": "DPI-007",
      "name": "QUIC-Block",
      "description": "QUIC protocol blocking - drops UDP:443 traffic to prevent QUIC/HTTP3 connections",
      "description_fa": "مسدودسازی پروتکل QUIC - حذف ترافیک UDP:443 برای جلوگیری از QUIC/HTTP3",
      "detection_method": "udp_port_443_filter",
      "response_pattern": "udp_drop",
      "timing_ms_min": 0,
      "timing_ms_max": 0,
      "affected_isps": [
        "AS41689",
        "AS197207",
        "AS39074",
        "AS34918",
        "AS24631",
        "AS12880",
        "AS44244"
      ],
      "technical_details": {
        "trigger": "UDP packets to port 443",
        "action": "Silent drop of all UDP:443 packets",
        "scope": "Complete UDP:443 blocking on some ISPs, partial on others",
        "bypass_methods": [
          "quic_over_tcp_relay",
          "hysteria2_on_custom_port",
          "tuic_on_custom_port",
          "udp_over_tcp_tunnelling"
        ]
      }
    },
    {
      "signature_id": "DPI-008",
      "name": "WireGuard-Detect",
      "description": "WireGuard protocol detection by matching handshake initiation message structure",
      "description_fa": "شناسایی پروتکل WireGuard با تطبیق ساختار پیام شروع handshake",
