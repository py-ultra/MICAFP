  "signatures": [
    {
      "signature_id": "DPI-001",
      "name": "TLS-ClientHello-Reset",
      "description": "TCP RST injection after detecting blocked SNI in TLS ClientHello",
      "description_fa": "تزریق RST پس از شناسایی SNI مسدود در ClientHello",
      "detection_method": "sni_pattern_match",
      "response_pattern": "tcp_rst_injection",
      "timing_ms_min": 95,
      "timing_ms_max": 320,
      "affected_isps": [
        "AS41689",
        "AS197207",
        "AS39074",
        "AS34918",
        "AS16322",
        "AS24631",
        "AS12880",
        "AS44244"
      ],
      "technical_details": {
        "trigger": "TLS ClientHello with SNI extension matching blocklist",
        "rst_flags": "RST+ACK",
        "rst_sequence": "uses original packet sequence number",
        "bypass_methods": [
          "fragmented_client_hello",
          "encrypted_sni_esni",
          "domain_fronting",
          "sni_padding",
          "sni_split"
        ]
      },
      "blocklist_sample": [
        "twitter.com",
        "facebook.com",
        "youtube.com",
        "telegram.org",
        "instagram.com",
        "whatsapp.com",
        "google.com",
        "wikipedia.org",
        "reddit.com",
        "signal.org",
        "protonvpn.com",
        "nordvpn.com",
        "expressvpn.com",
        "psiphon.ca",
        "lantern.io",
        "torproject.org"
      ]
    },
    {
      "signature_id": "DPI-002",
      "name": "HTTP-403-FAVA",
      "description": "HTTP 403 response with FAVA (Filtration And Violation Alert) body from Iranian filtering system",
      "description_fa": "پاسخ HTTP 403 با بدنه فاوای سیستم فیلترینگ ایران",
      "detection_method": "http_header_inspection",
      "response_pattern": "http_403_fava",
      "timing_ms_min": 50,
      "timing_ms_max": 150,
      "affected_isps": [
        "AS41689",
        "AS197207",
        "AS39074",
        "AS34918",
        "AS16322",
        "AS25184",
        "AS24631",
        "AS12880",
        "AS44244",
        "AS48434",
        "AS56402"
      ],
      "technical_details": {
        "trigger": "HTTP request to blocked URL",
        "response_code": 403,
        "response_headers": {
          "Server": "Fortinet",
          "X-FAVA": "filtered"
        },
        "response_body_contains": [
          "filternet",
          "10.10.34.34",
          "fava",
          "access denied"
        ],
        "bypass_methods": [
          "https_enforcement",
          "http_over_tls",
          "domain_fronting"
        ]
      }
    },
    {
      "signature_id": "DPI-003",
      "name": "Null-Route",
      "description": "Null routing / blackholing of IP addresses at the routing level",
      "description_fa": "مسیریابی تهی / بلک‌هول کردن آدرس‌های IP در سطح مسیریابی",
      "detection_method": "route_injection",
      "response_pattern": "connection_timeout",
      "timing_ms_min": 0,
      "timing_ms_max": 0,
      "affected_isps": [
        "AS12880",
        "AS41689",
        "AS34918",
        "AS16322",
        "AS24631",
        "AS44244"
      ],
      "technical_details": {
        "trigger": "Destination IP matches null-route blocklist",
        "behavior": "Packets silently dropped, no ICMP response",
        "detection_method": "TCP SYN goes unacknowledged, no RST received",
        "bypass_methods": [
          "cdn_relay",
          "domain_fronting",
          "proxy_chain",
          "p2p_relay"
        ]
      }
    },
