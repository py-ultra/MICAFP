  "snowflake": {
    "description": "Snowflake transport using WebRTC via broker. Front domains must be accessible from Iran.",
    "description_fa": "انتقال Snowflake با استفاده از WebRTC از طریق بروکر. دامنه‌های جلویی باید از ایران قابل دسترسی باشند.",
    "broker_url": "https://snowflake-broker.unifiedshield.dev/",
    "front_domain": "cdn.alicdn.com",
    "front_domain_alt": "cdn-go.cn",
    "ice_servers": [
      "stun:stun.l.google.com:19302",
      "stun:stun.ekiga.net",
      "stun:stun.schlund.de",
      "stun:stun.stunprotocol.org:3478"
    ],
    "max_peers": 3,
    "nat_remediation": true,
    "bridges": [
