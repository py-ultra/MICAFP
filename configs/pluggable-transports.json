        "bridge_id": "snowflake-alibaba-1",
        "name": "Snowflake via Alibaba CDN Front",
        "transport": "snowflake",
        "broker_url": "https://snowflake-broker.unifiedshield.dev/",
        "front_domain": "cdn.alicdn.com",
        "accessible_from_iran": true,
        "priority": 1,
        "status": "active"
      },
      {
        "bridge_id": "snowflake-tencent-1",
        "name": "Snowflake via Tencent CDN Front",
        "transport": "snowflake",
        "broker_url": "https://snowflake-broker.unifiedshield.dev/",
        "front_domain": "cdn-go.cn",
        "accessible_from_iran": true,
        "priority": 2,
        "status": "active"
      },
      {
        "bridge_id": "snowflake-huawei-1",
        "name": "Snowflake via Huawei CDN Front",
        "transport": "snowflake",
        "broker_url": "https://snowflake-broker.unifiedshield.dev/",
        "front_domain": "cdn.huaweicloud.com",
