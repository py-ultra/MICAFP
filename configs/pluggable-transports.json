  "transport_selection_strategy": {
    "default_transport": "meek",
    "selection_rules": [
      {
        "condition": "normal",
        "transport_order": [
          "meek",
          "snowflake",
          "obfs4"
        ],
        "meek_cdn_order": [
          "alibaba",
          "tencent",
          "baidu",
          "huawei",
          "azure"
        ]
      },
      {
        "condition": "high_censorship",
        "transport_order": [
          "meek",
          "snowflake"
        ],
        "meek_cdn_order": [
          "alibaba",
          "huawei",
          "tencent",
          "baidu"
        ],
        "notes": "Skip obfs4 during high censorship events"
      },
      {
        "condition": "national_intranet_mode",
        "transport_order": [
          "meek"
        ],
        "meek_cdn_order": [
          "alibaba",
          "huawei"
        ],
        "notes": "Only Chinese CDNs, only meek transport"
      },
      {
        "condition": "low_bandwidth",
        "transport_order": [
          "snowflake",
          "meek"
        ],
        "notes": "Snowflake uses WebRTC which is more bandwidth efficient"
      }
    ]
  },
