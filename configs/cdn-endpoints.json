  "relay_selection_strategy": {
    "description": "Strategy for selecting relay CDN based on conditions",
    "rules": [
      {
        "condition": "normal_operation",
        "preferred_cdns": [
          "alibaba_cdn",
          "tencent_cdn",
          "baidu_cdn",
          "huawei_cdn"
        ],
        "fallback_cdns": [
          "cloudfront",
          "fastly"
        ]
      },
      {
        "condition": "national_intranet_mode",
        "preferred_cdns": [
          "alibaba_cdn",
          "huawei_cdn"
        ],
        "fallback_cdns": [
          "tencent_cdn",
          "baidu_cdn"
        ]
      },
      {
        "condition": "high_censorship_event",
        "preferred_cdns": [
          "alibaba_cdn",
          "tencent_cdn",
          "huawei_cdn",
          "baidu_cdn"
        ],
        "fallback_cdns": [],
        "note": "Use all Chinese CDNs with rapid rotation, avoid Western CDNs entirely"
      },
      {
        "condition": "low_bandwidth",
        "preferred_cdns": [
          "alibaba_cdn"
        ],
        "fallback_cdns": [
          "tencent_cdn"
        ],
        "note": "Use highest bandwidth CDN with lowest latency"
      }
    ]
  },
