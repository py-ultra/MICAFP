{
  "name": "micafp-unifiedshield-vip-ultra-quantum-ultra",
  "version": "8.0.0",
  "private": true,
  "description": "MICAFP UnifiedShield VIP-ULTRA Quantum-Ultra v8.0 — Complete merge of all 13 source projects. Zero features removed.",
  "workspaces": [
    "dashboard",
    "extensions/chrome",
    "extensions/firefox",
    "workers/cloudflare",
    "workers/alibaba-cdn",
    "workers/arvan-cdn",
    "workers/baidu-cdn",
    "workers/bytedance-cdn",
    "workers/huawei-cdn",
    "workers/tencent-cdn",
    "workers/deno-relay",
    "workers/universal"
  ],
  "scripts": {
    "build:daemon":        "cd daemon && cargo build --release --features full",
    "build:daemon:quantum":"cd daemon && cargo build --release --features full,quantum-full",
    "build:android":       "bash scripts/cross-compile-android.sh",
    "build:ios":           "bash scripts/cross-compile-ios.sh",
    "build:linux":         "bash scripts/build-all.sh linux",
    "build:windows":       "bash scripts/build-all.sh windows",
    "build:openwrt":       "bash scripts/package-openwrt.sh",
    "build:wasm":          "cd wasm-obfuscator && wasm-pack build --target web --out-dir ../extensions/chrome/wasm",
    "build:chrome":        "cd extensions/chrome && pnpm build",
    "build:firefox":       "cd extensions/firefox && pnpm build",
    "build:dashboard":     "cd dashboard && pnpm build",
    "build:workers:cf":    "cd workers/cloudflare && pnpm build",
    "build:workers:ali":   "cd workers/alibaba-cdn && pnpm build",
    "build:workers:arvan": "cd workers/arvan-cdn && pnpm build",
    "build:workers:baidu": "cd workers/baidu-cdn && pnpm build",
    "build:workers:bd":    "cd workers/bytedance-cdn && pnpm build",
    "build:workers:hw":    "cd workers/huawei-cdn && pnpm build",
    "build:workers:tc":    "cd workers/tencent-cdn && pnpm build",
    "build:workers:deno":  "cd workers/deno-relay && deno task build",
    "build:workers:all":   "pnpm build:workers:cf && pnpm build:workers:ali && pnpm build:workers:arvan && pnpm build:workers:baidu && pnpm build:workers:bd && pnpm build:workers:hw && pnpm build:workers:tc && pnpm build:workers:deno",
    "build:flutter":       "cd flutter && flutter build apk --release && flutter build ios --release",
    "build:all":           "bash scripts/build-all.sh",
    "test:daemon":         "cd daemon && cargo test --features full",
    "test:censorship":     "cd tests/censorship-simulation && python3 test_bypass_effectiveness.py",
    "test:all":            "cd daemon && cargo test && cd ../tests/censorship-simulation && python3 test_bypass_effectiveness.py",
    "health":              "bash scripts/health-check.sh",
    "benchmark":           "bash scripts/benchmark-transports.sh",
    "checksums":           "bash scripts/generate-checksums.sh",
    "sign":                "bash scripts/sign-binaries.sh",
    "update:iran-ips":     "bash scripts/update-iran-ip-ranges.sh",
    "detect:isp":          "bash scripts/detect-isp.sh",
    "rotate:identity":     "bash scripts/rotate-identity.sh",
    "publish:ipfs":        "bash scripts/publish-ipfs.sh",
    "deploy":              "bash deploy.sh",
    "quickstart":          "bash quickstart.sh"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "pnpm":       "^9.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
